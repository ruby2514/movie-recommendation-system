Info": {"status": "ok", "timestamp": 1777563193447, "user_tz": 240, "elapsed": 26, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "870a0ef1-53b8-47fb-fb16-a73d0029e118"}, "execution_count": 9, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["Number of users: 17615\n", "Number of movies: 16121\n", "Number of ratings: 72665\n", "Sparsity: 99.97%\n"]}]}, {"cell_type": "code", "source": ["import matplotlib.pyplot as plt\n", "import seaborn as sns\n", "\n", "plt.figure(figsize=(8, 5))\n", "sns.countplot(data=df, x='rating') # Changed 'Rating' to 'rating'\n", "\n", "plt.xlabel('Rating')\n", "plt.ylabel('Count')\n", "plt.title('Distribution of Ratings')\n", "plt.show()"], "metadata": {"colab": {"base_uri": "https://localhost:8080/", "height": 487}, "id": "gtnt_4TrBlDJ", "executionInfo": {"status": "ok", "timestamp": 1777563344802, "user_tz": 240, "elapsed": 1317, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "97a98e2d-207b-4520-ddb5-d8387ec1f5b7"}, "execution_count": 12, "outputs": [{"output_type": "display_data", "data": {"text/plain": ["<Figure size 800x500 with 1 Axes>"], "image/png": "\n"}, "metadata": {}}]}, {"cell_type": "code", "source": ["ratings_per_user = df.groupby('userId')['rating'].count()\n", "ratings_per_movie = df.groupby('movieId')['rating'].count()"], "metadata": {"id": "80qYaF2xCDMZ", "executionInfo": {"status": "ok", "timestamp": 1777563367987, "user_tz": 240, "elapsed": 5, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}}, "execution_count": 13, "outputs": []}, {"cell_type": "code", "source": ["fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n", "\n", "# Plot 1 - Ratings per user\n", "axes[0].hist(ratings_per_user, bins=50, color='steelblue')\n", "axes[0].set_title('Ratings per User')\n", "axes[0].set_xlabel('Number of Ratings')\n", "axes[0].set_ylabel('Number of Users')\n", "\n", "# Plot 2 - Ratings per movie\n", "axes[1].hist(ratings_per_movie, bins=50, color='steelblue')\n", "axes[1].set_title('Rating per Movie')\n", "axes[1].set_xlabel('Number of Ratings')\n", "axes[1].set_ylabel('Number of Movies')\n", "\n", "plt.tight_layout()\n", "plt.show()"], "metadata": {"colab": {"base_uri": "https://localhost:8080/", "height": 417}, "id": "k4kV7sGwCH8g", "executionInfo": {"status": "ok", "timestamp": 1777563372051, "user_tz": 240, "elapsed": 397, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "04da6526-be89-48fc-b570-6903f6b9a2af"}, "execution_count": 14, "outputs": [{"output_type": "display_data", "data": {"text/plain": ["<Figure size 1400x500 with 2 Axes>"], "image/png": "\n"}, "metadata": {}}]}, {"cell_type": "code", "source": ["from google.colab import _message\n", "import json\n", "\n", "notebook_content = _message.blocking_request('get_ipynb')\n", "with open('/content/movie-recommendation-system/01_eda.ipynb', 'w') as f:\n", "    json.dump(notebook_content, f)"], "metadata": {"id": "zZS_gwYwCbnA"}, "execution_count": null, "outputs": []}]}}