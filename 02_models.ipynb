{"ipynb": {"nbformat": 4, "nbformat_minor": 0, "metadata": {"colab": {"provenance": []}, "kernelspec": {"name": "python3", "display_name": "Python 3"}, "language_info": {"name": "python"}}, "cells": [{"cell_type": "code", "source": ["!pip install \"numpy<2\" --quiet\n", "!pip install scikit-surprise --quiet"], "metadata": {"id": "8Nm3uU3oAyCO", "executionInfo": {"status": "ok", "timestamp": 1777667525804, "user_tz": 240, "elapsed": 11455, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}}, "execution_count": 1, "outputs": []}, {"cell_type": "markdown", "source": ["#1 Data loading & statistics"], "metadata": {"id": "US8tZV3WHMxH"}}, {"cell_type": "code", "source": ["import os\n", "os.chdir('/root/movie-recommendation-system')\n", "!ls"], "metadata": {"colab": {"base_uri": "https://localhost:8080/"}, "id": "WfKD2Nm_FLOs", "executionInfo": {"status": "ok", "timestamp": 1777667525976, "user_tz": 240, "elapsed": 157, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "410f615d-0e62-41d5-bebb-404d848126a9"}, "execution_count": 2, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["01_eda.ipynb  02_models.ipynb  movie-ratings.txt  README.md\n"]}]}, {"cell_type": "code", "source": ["import pandas as pd\n", "\n", "df = pd.read_csv('movie-ratings.txt',\n", "                  header=None,\n", "                  names=['userId', 'movieId', 'categoryId', 'reviewId', 'rating', 'date'])\n", "\n", "print(df.shape)\n", "print(df.head())\n", "print(df.dtypes)"], "metadata": {"colab": {"base_uri": "https://localhost:8080/"}, "id": "txRWnzhTBZ7Q", "executionInfo": {"status": "ok", "timestamp": 1777667526404, "user_tz": 240, "elapsed": 426, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "5d0a3972-cc6d-4164-9b9f-d575442e185b"}, "execution_count": 3, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["(72665, 6)\n", "   userId  movieId  categoryId  reviewId  rating        date\n", "0       1        1           1         1       5  2000-07-12\n", "1       2        1           1         2       5  2000-07-12\n", "2       3        1           1         3       5  2000-07-12\n", "3       4        1           1         4       4  2000-07-12\n", "4       5        1           1         5       4  2000-07-12\n", "userId         int64\n", "movieId        int64\n", "categoryId     int64\n", "reviewId       int64\n", "rating         int64\n", "date          object\n", "dtype: object\n"]}]}, {"cell_type": "code", "source": ["num_users = df['userId'].nunique()\n", "num_movies = df['movieId'].nunique()\n", "num_ratings = df.shape[0]\n", "sparsity = 1 - (num_ratings / (num_users * num_movies))\n", "\n", "print(f'Number of users: {num_users}')\n", "print(f'Number of movies: {num_movies}')\n", "print(f'Number of ratings: {num_ratings}')\n", "print(f\"Sparsity: {(sparsity * 100):.2f}%\")"], "metadata": {"colab": {"base_uri": "https://localhost:8080/"}, "id": "yseUirNgBca-", "executionInfo": {"status": "ok", "timestamp": 1777667526431, "user_tz": 240, "elapsed": 14, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "7e88a332-a85e-4547-ddcb-69034b983ca1"}, "execution_count": 4, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["Number of users: 17615\n", "Number of movies: 16121\n", "Number of ratings: 72665\n", "Sparsity: 99.97%\n"]}]}, {"cell_type": "markdown", "source": ["#2 Visualizations & data quality"], "metadata": {"id": "AoOqGhJfHWcy"}}, {"cell_type": "code", "source": ["import matplotlib.pyplot as plt\n", "import seaborn as sns\n", "\n", "plt.figure(figsize=(8, 5))\n", "sns.countplot(data=df, x='rating') # Changed 'Rating' to 'rating'\n", "\n", "plt.xlabel('Rating')\n", "plt.ylabel('Count')\n", "plt.title('Distribution of Ratings')\n", "plt.show()"], "metadata": {"colab": {"base_uri": "https://localhost:8080/", "height": 487}, "id": "gtnt_4TrBlDJ", "executionInfo": {"status": "ok", "timestamp": 1777667527885, "user_tz": 240, "elapsed": 1442, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "1ccd6640-90d9-4b0b-944b-a5dc0a14cc84"}, "execution_count": 5, "outputs": [{"output_type": "display_data", "data": {"text/plain": ["<Figure size 800x500 with 1 Axes>"], "image/png": "\n"}, "metadata": {}}]}, {"cell_type": "code", "source": ["ratings_per_user = df.groupby('userId')['rating'].count()\n", "ratings_per_movie = df.groupby('movieId')['rating'].count()"], "metadata": {"id": "80qYaF2xCDMZ", "executionInfo": {"status": "ok", "timestamp": 1777667527895, "user_tz": 240, "elapsed": 15, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}}, "execution_count": 6, "outputs": []}, {"cell_type": "code", "source": ["fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n", "\n", "# Plot 1 - Ratings per user\n", "axes[0].hist(ratings_per_user, bins=50, color='steelblue')\n", "axes[0].set_title('Ratings per User')\n", "axes[0].set_xlabel('Number of Ratings')\n", "axes[0].set_ylabel('Number of Users')\n", "\n", "# Plot 2 - Ratings per movie\n", "axes[1].hist(ratings_per_movie, bins=50, color='steelblue')\n", "axes[1].set_title('Rating per Movie')\n", "axes[1].set_xlabel('Number of Ratings')\n", "axes[1].set_ylabel('Number of Movies')\n", "\n", "plt.tight_layout()\n", "plt.show()"], "metadata": {"colab": {"base_uri": "https://localhost:8080/", "height": 272}, "id": "k4kV7sGwCH8g", "executionInfo": {"status": "ok", "timestamp": 1777667528726, "user_tz": 240, "elapsed": 843, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "6140400a-e730-48c9-f0a1-3fb4b0275f57"}, "execution_count": 7, "outputs": [{"output_type": "display_data", "data": {"text/plain": ["<Figure size 1400x500 with 2 Axes>"], "image/png": "\n"}, "metadata": {}}]}, {"cell_type": "markdown", "source": ["#3 Global Average model"], "metadata": {"id": "Dbt_Xw5uHkkP"}}, {"cell_type": "code", "source": ["from surprise import Dataset, Reader\n", "from surprise.model_selection import train_test_split\n", "from surprise import accuracy\n", "from surprise import NormalPredictor, BaselineOnly\n", "\n", "\n", "# Step 1: Tell Surprise the rating scale\n", "reader = Reader(rating_scale=(1, 5))\n", "\n", "# Step 2: Load data from pandas dataframe\n", "data = Dataset.load_from_df(df[['userId', 'movieId', 'rating']], reader)\n", "\n", "#Step 3: Split 80/20\n", "trainset, testset = train_test_split(data, test_size=0.2, random_state=42)\n", "\n", "model = BaselineOnly()\n", "model.fit(trainset)\n", "predictions = model.test(testset)\n", "\n", "rmse = accuracy.rmse(predictions)\n", "mae = accuracy.mae(predictions)\n", "print(f\"Global Average RMSE: {rmse:.4f}\")\n", "print(f\"Global Average MAE: {mae:.4f}\")"], "metadata": {"id": "0533peDUDDU7", "colab": {"base_uri": "https://localhost:8080/"}, "executionInfo": {"status": "ok", "timestamp": 1777667529902, "user_tz": 240, "elapsed": 1175, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "ffc36f84-20c0-417a-cd83-8e0ac1fc0ade"}, "execution_count": 8, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["Estimating biases using als...\n", "RMSE: 0.9541\n", "MAE:  0.7422\n", "Global Average RMSE: 0.9541\n", "Global Average MAE: 0.7422\n"]}]}, {"cell_type": "code", "source": ["from surprise.model_selection import cross_validate\n", "\n", "print(\"Cross-validation for Global Average:\")\n", "cv_results_baseline = cross_validate(\n", "    BaselineOnly(),\n", "    data,\n", "    measures=['RMSE', 'MAE'],\n", "    cv=5,\n", "    verbose=True\n", ")"], "metadata": {"colab": {"base_uri": "https://localhost:8080/"}, "id": "FnrLQSsLPCFE", "executionInfo": {"status": "ok", "timestamp": 1777667535127, "user_tz": 240, "elapsed": 5223, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "707b5765-1bb2-4a0b-b0cd-bb275dc363f3"}, "execution_count": 9, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["Cross-validation for Global Average:\n", "Estimating biases using als...\n", "Estimating biases using als...\n", "Estimating biases using als...\n", "Estimating biases using als...\n", "Estimating biases using als...\n", "Evaluating RMSE, MAE of algorithm BaselineOnly on 5 split(s).\n", "\n", "                  Fold 1  Fold 2  Fold 3  Fold 4  Fold 5  Mean    Std     \n", "RMSE (testset)    0.9428  0.9462  0.9417  0.9454  0.9398  0.9432  0.0023  \n", "MAE (testset)     0.7341  0.7378  0.7312  0.7315  0.7298  0.7329  0.0028  \n", "Fit time          0.51    1.44    0.29    0.28    0.29    0.56    0.45    \n", "Test time         0.08    0.94    0.04    0.18    0.04    0.26    0.35    \n"]}]}, {"cell_type": "markdown", "source": ["#4 Second model"], "metadata": {"id": "a56czt4EHoFv"}}, {"cell_type": "code", "source": ["from surprise import KNNBasic\n", "\n", "# User-Based CF\n", "sim_options = {\n", "    'name': 'cosine',      # similarity metric\n", "    'user_based': True      # True = user-based, False = item-based\n", "}\n", "\n", "model_ubcf = KNNBasic(k=40, sim_options=sim_options)\n", "model_ubcf.fit(trainset)\n", "predictions_ubcf = model_ubcf.test(testset)\n", "\n", "rmse_ubcf = accuracy.rmse(predictions_ubcf)\n", "mae_ubcf = accuracy.mae(predictions_ubcf)\n", "print(f\"User-Based CF RMSE: {rmse_ubcf:.4f}\")\n", "print(f\"User-Based CF MAE: {mae_ubcf:.4f}\")"], "metadata": {"colab": {"base_uri": "https://localhost:8080/"}, "id": "Mx91HoaKGMtx", "executionInfo": {"status": "ok", "timestamp": 1777667539031, "user_tz": 240, "elapsed": 3893, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "2e907e9c-e498-42f8-f33d-7c32be9e26f9"}, "execution_count": 10, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["Computing the cosine similarity matrix...\n", "Done computing similarity matrix.\n", "RMSE: 1.0839\n", "MAE:  0.8200\n", "User-Based CF RMSE: 1.0839\n", "User-Based CF MAE: 0.8200\n"]}]}, {"cell_type": "code", "source": ["print(\"Cross-validation for User-Based CF:\")\n", "cv_results_ubcf = cross_validate(\n", "    KNNBasic(k=40, sim_options=sim_options),\n", "    data,\n", "    measures=['RMSE', 'MAE'],\n", "    cv=5,\n", "    verbose=True\n", ")"], "metadata": {"colab": {"base_uri": "https://localhost:8080/"}, "id": "efp7d6hCPNIh", "executionInfo": {"status": "ok", "timestamp": 1777667562238, "user_tz": 240, "elapsed": 23052, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "f1569f9b-8a4d-44ba-c57d-c88ecd7c0fc7"}, "execution_count": 11, "outputs": [{"output_type": "stream", "name": "stdout", "text": ["Cross-validation for User-Based CF:\n", "Computing the cosine similarity matrix...\n", "Done computing similarity matrix.\n", "Computing the cosine similarity matrix...\n", "Done computing similarity matrix.\n", "Computing the cosine similarity matrix...\n", "Done computing similarity matrix.\n", "Computing the cosine similarity matrix...\n", "Done computing similarity matrix.\n", "Computing the cosine similarity matrix...\n", "Done computing similarity matrix.\n", "Evaluating RMSE, MAE of algorithm KNNBasic on 5 split(s).\n", "\n", "                  Fold 1  Fold 2  Fold 3  Fold 4  Fold 5  Mean    Std     \n", "RMSE (testset)    1.0719  1.0671  1.0649  1.0727  1.0776  1.0708  0.0044  \n", "MAE (testset)     0.8108  0.8074  0.8090  0.8148  0.8214  0.8127  0.0050  \n", "Fit time          3.46    4.28    3.63    4.41    4.25    4.01    0.38    \n", "Test time         0.50    0.51    0.37    0.34    0.43    0.43    0.07    \n"]}]}, {"cell_type": "markdown", "source": ["#5 Evaluation & comparison"], "metadata": {"id": "U5_2CmZ3JlQd"}}, {"cell_type": "code", "source": ["# Results data\n", "models = ['Global Average', 'User-Based CF']\n", "rmse_scores = [0.9541, 1.0839]\n", "mae_scores = [0.7422, 0.8200]\n", "\n", "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n", "\n", "# RMSE comparison\n", "axes[0].bar(models, rmse_scores, color=['steelblue', 'coral'])\n", "axes[0].set_title('RMSE Comparison')\n", "axes[0].set_ylabel('RMSE')\n", "axes[0].set_ylim(0, 1.5)\n", "\n", "# MAE comparison\n", "axes[1].bar(models, mae_scores, color=['steelblue', 'coral'])\n", "axes[1].set_title('MAE Comparison')\n", "axes[1].set_ylabel('MAE')\n", "axes[1].set_ylim(0, 1.5)\n", "\n", "plt.tight_layout()\n", "plt.show()"], "metadata": {"colab": {"base_uri": "https://localhost:8080/", "height": 315}, "id": "8HJhPIC0JmmT", "executionInfo": {"status": "ok", "timestamp": 1777667562520, "user_tz": 240, "elapsed": 265, "user": {"displayName": "Ruby Villalona Grullon", "userId": "00247299250494899794"}}, "outputId": "cd03ab9c-ff44-4c9d-8159-296627ecc7c1"}, "execution_count": 12, "outputs": [{"output_type": "display_data", "data": {"text/plain": ["<Figure size 1200x500 with 2 Axes>"], "image/png": "\n"}, "metadata": {}}]}, {"cell_type": "code", "source": ["from google.colab import _message\n", "import json\n", "\n", "notebook_content = _message.blocking_request('get_ipynb')\n", "with open('/root/movie-recommendation-system/02_models.ipynb', 'w') as f:\n", "    json.dump(notebook_content, f)"], "metadata": {"id": "nDDWEQJiQevG"}, "execution_count": null, "outputs": []}]}}